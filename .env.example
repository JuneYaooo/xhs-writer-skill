# ============================================================================
# xhs-writer-skill -- 可选配置（写作本身不需要任何 key）
# ============================================================================
#
# 本 skill 默认仅使用 Claude 内置工具（WebSearch / WebFetch / Bash / Read），
# 不需要配置任何 API key 就能完整跑通写作、拆卡、caption/hashtags 生成。
#
# 下面几组环境变量都是 **可选** 的，只在你想接入自己的 text-to-image 服务
# 自动给卡片出配图时才需要填。
#
# ============================================================================

# ---- 可选：text-to-image 服务（用于自动给卡片出 3:4 竖版配图）-------------
# 本 skill 不内置任何生图 endpoint，需要你自己填信任的服务。
# 留空则跳过自动生图，卡片仅输出文字方案。
#
# 示例：OpenAI 兼容服务（Nano Banana、Gemini Image、Flux 等通常都有兼容网关）
# T2I_BASE_URL=https://your-openai-compatible-relay.example.com/v1
# T2I_API_KEY=sk-your-key-here
# T2I_MODEL_NAME=gpt-image-2
# T2I_ASPECT_RATIO=3:4

T2I_BASE_URL=
T2I_API_KEY=
T2I_MODEL_NAME=
T2I_ASPECT_RATIO=3:4

# ---- 可选：图床（把本地图片上传成可外链的 URL，方便在 meta.json 里引用）--
# OSS_ENDPOINT=
# OSS_BUCKET=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
